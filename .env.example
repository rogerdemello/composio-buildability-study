# Copy to .env and fill in. Never commit real keys (.env is git-ignored).

# ---- LLM backend --------------------------------------------------------
# "nvidia" = NVIDIA NIM (OpenAI-compatible, build.nvidia.com)  [default]
# "anthropic" = Anthropic Claude
LLM_PROVIDER=nvidia

# NVIDIA NIM (get a key at https://build.nvidia.com -> your profile -> API keys)
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Only needed if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (defaults are chosen per provider in config.py)
#   nvidia    -> meta/llama-3.3-70b-instruct (research), meta/llama-3.1-405b-instruct (verify/pattern)
#   anthropic -> claude-sonnet-5 (research), claude-opus-4-8 (verify/pattern)
# RESEARCH_MODEL=meta/llama-3.3-70b-instruct
# VERIFY_MODEL=meta/llama-3.1-405b-instruct
# PATTERN_MODEL=meta/llama-3.1-405b-instruct

# ---- Providers (research evidence) --------------------------------------
COMPOSIO_API_KEY=comp_...        # powers the COMPOSIO_SEARCH provider (dogfooding)
COMPOSIO_USER_ID=default
TAVILY_API_KEY=tvly-...          # optional search provider
FIRECRAWL_API_KEY=fc-...         # optional scrape/search provider

# ---- Orchestration ------------------------------------------------------
CONCURRENCY=5
VERIFY_SAMPLE=20
