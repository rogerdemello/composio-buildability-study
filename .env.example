# Copy to .env and fill in. Never commit real keys.
ANTHROPIC_API_KEY=sk-ant-...
COMPOSIO_API_KEY=comp_...        # powers the COMPOSIO_SEARCH provider
COMPOSIO_USER_ID=default
TAVILY_API_KEY=tvly-...          # optional search provider
FIRECRAWL_API_KEY=fc-...         # optional scrape/search provider
RESEARCH_MODEL=claude-sonnet-5
VERIFY_MODEL=claude-opus-4-8
PATTERN_MODEL=claude-opus-4-8
CONCURRENCY=5
VERIFY_SAMPLE=20
